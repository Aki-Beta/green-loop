# Green Loop API - Environment Variables
# Copy to .env and customize

# Flask
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_ENV=development

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database
DATABASE_URL=sqlite:///greenloop.db
# For PostgreSQL: postgresql://user:pass@localhost:5432/greenloop

# Optional
PORT=5000